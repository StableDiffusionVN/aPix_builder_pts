{
  "app": {
    "name": "Klein_Edit_Image"
  },
  "input": {
    "checkpoint_klein": {
      "id": "1-ckpt_name",
      "ui": {
        "type": "checkpoints",
        "label": "Checkpoint Klein",
        "value": "Flux2-klein-9b.safetensors"
      }
    },
    "note": {
      "ui": {
        "type": "note",
        "markdown": "| *Tải checkpoint Klein* [tại đây](https://huggingface.co/StableDiffusionVN/Flux2/blob/main/Checkpoint/Flux2-klein-9b.safetensors)"
      }
    },
    "hinh_anh_chinh_sua": {
      "id": "5-image",
      "ui": {
        "type": "image",
        "label": "Hình ảnh chỉnh sửa"
      }
    },
    "prompt_chinh_sua": {
      "id": "3-text",
      "ui": {
        "type": "text",
        "label": "Prompt chỉnh sửa"
      }
    },
    "output_size": {
      "id": "14-resize_type.longer_size",
      "ui": {
        "type": "int",
        "label": "Output size",
        "minimum": 512,
        "maximum": 2048,
        "step": 1,
        "value": 2048
      }
    },
    "steps": {
      "id": "2-steps",
      "ui": {
        "type": "int",
        "label": "Steps",
        "minimum": 0,
        "maximum": 20,
        "step": 1,
        "value": 4
      }
    },
    "seed": {
      "id": "2-seed",
      "ui": {
        "type": "seed",
        "label": "Seed",
        "minimum": 0,
        "step": 1,
        "value": "random_seed"
      }
    }
  },
  "output": {
    "anh_ket_qua": {
      "id": "11",
      "ui": {
        "type": "image",
        "label": "Ảnh kết quả"
      }
    }
  }
