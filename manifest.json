{
  "manifestVersion": 5,
  "id": "com.apix.builder.photoshop",
  "name": "aPix Builder",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/apix-icon-24.png",
      "scale": [1],
      "theme": ["dark", "darkest", "light", "lightest"],
      "species": ["generic"]
    },
    {
      "width": 24,
      "height": 24,
      "path": "icons/apix-icon-48.png",
      "scale": [2],
      "theme": ["dark", "darkest", "light", "lightest"],
      "species": ["generic"]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all",
      "allowInsecureRequests": true
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "apixBuilderPanel",
      "label": {
        "default": "aPix Builder"
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/apix-panel-23.png",
          "scale": [1],
          "theme": ["dark", "darkest", "light", "lightest"],
          "species": ["generic"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/apix-panel-46.png",
          "scale": [2],
          "theme": ["dark", "darkest", "light", "lightest"],
          "species": ["generic"]
        }
      ],
      "minimumSize": {
        "width": 320,
        "height": 520
      },
      "maximumSize": {
        "width": 720,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 780
      }
    }
  ]
}
