{
  "manifestVersion": 5,
  "id": "com.apix.builder.photoshop",
  "name": "aPix Builder",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": "all",
      "allowInsecureRequests": true
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "apixBuilderPanel",
      "label": {
        "default": "aPix Builder"
      },
      "minimumSize": {
        "width": 320,
        "height": 520
      },
      "maximumSize": {
        "width": 720,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 780
      }
    }
  ]
}
